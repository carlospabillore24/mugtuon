# MugTuon PHP Environment Configuration
# Copy this file to .env.php and fill in your production values.

# Database (MySQL)
DB_HOST=localhost
DB_NAME=mugtuon
DB_USER=root
DB_PASS=your_db_password

# JWT (change this to a random 64-char hex string in production)
JWT_SECRET=CHANGE-THIS-TO-A-RANDOM-SECRET
JWT_EXPIRES_IN=604800

# Email (Gmail SMTP — use App Password, not regular password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM=MugTuon <your-email@gmail.com>

# App
BASE_URL=https://your-domain.com
APP_ENV=production
